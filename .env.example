# Discord webhook for alerts
DISCORD_WEBHOOK_URL=

# Kalshi API (optional for Phase 1 read-only, required for Phase 2)
KALSHI_API_KEY=
KALSHI_API_SECRET=

# Scan interval in seconds
SCAN_INTERVAL=60

# Minimum spread threshold (percentage, after fees)
MIN_SPREAD_THRESHOLD=4.0

# Match confidence threshold (0-100)
MIN_MATCH_CONFIDENCE=70
